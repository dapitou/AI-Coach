    private fun getRoundedBg(color: Int, vararg radii: Float): GradientDrawable {
        return GradientDrawable().apply {
            setColor(color)
            if (radii.size == 1) cornerRadius = radii[0]
            else if (radii.size == 4) cornerRadii = floatArrayOf(radii[2], radii[2], radii[3], radii[3], radii[1], radii[1], radii[0], radii[0])
            if (radii.size == 1) cornerRadius = radii[0]
        }
    }

    private fun saveConfigToJson(uri: Uri) {
        try {
            val json = JSONObject().apply {
                put("modeCode", motorConfig.modeCode)
                put("param1", motorConfig.param1)
                put("param2", motorConfig.param2)
                put("isSmooth", motorConfig.isSmooth)
                put("activationSmoothRate", motorConfig.activationSmoothRate)
                put("unloadDuration", motorConfig.unloadDuration.toDouble())
                put("returnRatio", motorConfig.returnRatio.toDouble())
                put("releaseProtectEnable", motorConfig.releaseProtectEnable)
                put("releaseSpeedLimit", motorConfig.releaseSpeedLimit)
                put("releaseDuration", motorConfig.releaseDuration)
                put("pullComp", motorConfig.pullComp)
                put("returnComp", motorConfig.returnComp)
                put("balanceSwitch", motorConfig.balanceSwitch)
                put("userGender", StrokeConfig.userGender)
                put("userHeight", StrokeConfig.userHeight.toDouble())
                put("strokeCurrentIndex", StrokeConfig.currentIndex)
                put("isFreeTraining", StrokeConfig.isFreeTraining)
            }
            contentResolver.openOutputStream(uri)?.use { it.write(json.toString(4).toByteArray()) }
            Toast.makeText(this, "配置导出成功", Toast.LENGTH_SHORT).show()
        } catch (e: Exception) {
            Toast.makeText(this, "导出失败: ${e.message}", Toast.LENGTH_SHORT).show()
        }
    }

    private fun loadConfigFromJson(uri: Uri) {
        try {
            val sb = StringBuilder()
            contentResolver.openInputStream(uri)?.use { inputStream ->
                BufferedReader(InputStreamReader(inputStream)).use { reader ->
                    var line: String? = reader.readLine()
                    while (line != null) { sb.append(line); line = reader.readLine() }
                }
            }
            val json = JSONObject(sb.toString())
            
            motorConfig.apply {
                modeCode = json.optInt("modeCode", modeCode)
                param1 = json.optInt("param1", param1)
                param2 = json.optInt("param2", param2)
                isSmooth = json.optBoolean("isSmooth", isSmooth)
                activationSmoothRate = json.optInt("activationSmoothRate", activationSmoothRate)
                unloadDuration = json.optDouble("unloadDuration", unloadDuration.toDouble()).toFloat()
                returnRatio = json.optDouble("returnRatio", returnRatio.toDouble()).toFloat()
                releaseProtectEnable = json.optBoolean("releaseProtectEnable", releaseProtectEnable)
                releaseSpeedLimit = json.optInt("releaseSpeedLimit", releaseSpeedLimit)
                releaseDuration = json.optInt("releaseDuration", releaseDuration)
                pullComp = json.optInt("pullComp", pullComp)
                returnComp = json.optInt("returnComp", returnComp)
                balanceSwitch = json.optBoolean("balanceSwitch", balanceSwitch)
            }
            StrokeConfig.apply {
                userGender = json.optInt("userGender", userGender)
                userHeight = json.optDouble("userHeight", userHeight.toDouble()).toFloat()
                currentIndex = json.optInt("strokeCurrentIndex", currentIndex)
                isFreeTraining = json.optBoolean("isFreeTraining", isFreeTraining)
            }
            
            applySettings()
            Toast.makeText(this, "配置导入成功并已下发", Toast.LENGTH_SHORT).show()
        } catch (e: Exception) {
            Toast.makeText(this, "导入失败: 格式错误", Toast.LENGTH_SHORT).show()
        }
    }

