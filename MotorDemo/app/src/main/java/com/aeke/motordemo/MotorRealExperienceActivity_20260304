// 行程阈值配置策略 (Stroke Policy)
// ===================================================================================
data class StrokePolicy(
    val name: String,
    var refStroke: Float,
    var staticZone: Float,
    var jitterZone: Float,
    var triggerThreshold: Float,
    var returnThreshold: Float
)

object StrokeConfig {
    // [精准还原] 严格对齐产品定义 MD 文档中的 男女标准库数值
    val malePolicies = listOf(
        StrokePolicy("超短行程", 20f, 2.0f, 3.0f, 3.5f, 2.0f),
        StrokePolicy("短行程", 40f, 2.0f, 4.0f, 5.0f, 3.0f),
        StrokePolicy("中行程", 60f, 2.0f, 4.0f, 7.0f, 4.5f),
        StrokePolicy("长行程", 90f, 2.0f, 4.0f, 8.0f, 5.0f)
    )
    val femalePolicies = listOf(
        StrokePolicy("超短行程", 15f, 2.0f, 3.0f, 2.5f, 1.5f),
        StrokePolicy("短行程", 30f, 2.0f, 4.0f, 4.0f, 2.5f),
        StrokePolicy("中行程", 50f, 2.0f, 4.0f, 6.0f, 4.0f),
        StrokePolicy("长行程", 75f, 2.0f, 4.0f, 7.0f, 4.0f)
    )
    var maleBounds = floatArrayOf(30f, 50f, 75f)     // 相邻两级的科学中位数边界
    var femaleBounds = floatArrayOf(22.5f, 40f, 62.5f)

    @Volatile var currentIndex = 2 
    @Volatile var isFreeTraining = false
    @Volatile var userGender = 0 
    @Volatile var userHeight = 180f

    fun getScaledPolicy(): StrokePolicy {
        val basePolicies = if (userGender == 0) malePolicies else femalePolicies
        val baseHeight = if (userGender == 0) 180f else 160f
        val scale = (userHeight / baseHeight).coerceIn(0.5f, 1.5f)
        val p = basePolicies[currentIndex]
        return StrokePolicy(p.name, p.refStroke * scale, p.staticZone, p.jitterZone, p.triggerThreshold * scale, p.returnThreshold * scale)
    }
    
    fun getScaledBounds(): FloatArray {
        val b = if (userGender == 0) maleBounds else femaleBounds
        val scale = (userHeight / (if (userGender == 0) 180f else 160f)).coerceIn(0.5f, 1.5f)
        return floatArrayOf(b[0]*scale, b[1]*scale, b[2]*scale)
    }
}

