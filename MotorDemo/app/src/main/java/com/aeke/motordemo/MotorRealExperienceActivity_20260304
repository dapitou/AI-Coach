    private fun showStrokeSettingsPage(root: ViewGroup) {
        settingsOverlay?.let { root.removeView(it) }
        val overlay = ScrollView(this).apply {
            layoutParams = ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT)
            background = getRoundedBg(colorBackground, 0f)
            isClickable = true
        }
        val container = LinearLayout(this).apply {
            orientation = LinearLayout.VERTICAL
            setPadding(32, 32, 32, 32)
        }
        val header = LinearLayout(this).apply {
            orientation = LinearLayout.HORIZONTAL
            gravity = Gravity.CENTER_VERTICAL
            setPadding(0,0,0,24)
            addView(TextView(this@MotorRealExperienceActivity).apply { 
                text = "行程阈值配置策略"; textSize = 24f; setTextColor(Color.WHITE); typeface = Typeface.DEFAULT_BOLD 
                layoutParams = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f)
            })
            addView(Button(this@MotorRealExperienceActivity).apply { 
                text = "关闭并生效"; setTextColor(Color.WHITE); background = getPressableBg(Color.DKGRAY, 16f)
                setOnClickListener {
                    root.removeView(overlay); settingsOverlay = null
                    Toast.makeText(context, "阈值配置已生效", Toast.LENGTH_SHORT).show()
                } 
            })
        }
        container.addView(header)

        var editingGender = 0 
        val contentBox = LinearLayout(this).apply { orientation = LinearLayout.VERTICAL }
        
        val tabRow = LinearLayout(this).apply { orientation = LinearLayout.HORIZONTAL; setPadding(0,0,0,16) }
        val btnMale = TextView(this).apply { text = "男版基准 (180cm)"; textSize = 16f; setPadding(24,12,24,12); layoutParams = LinearLayout.LayoutParams(0,-2,1f); gravity = Gravity.CENTER }
        val btnFemale = TextView(this).apply { text = "女版基准 (160cm)"; textSize = 16f; setPadding(24,12,24,12); layoutParams = LinearLayout.LayoutParams(0,-2,1f); gravity = Gravity.CENTER }
        
        fun renderContent() {
            contentBox.removeAllViews()
            val policies = if (editingGender == 0) StrokeConfig.malePolicies else StrokeConfig.femalePolicies
            val bounds = if (editingGender == 0) StrokeConfig.maleBounds else StrokeConfig.femaleBounds
            
            contentBox.addView(createSectionHeader("自由训练行程推断边界 (链式自适应)"))
            val sbs = arrayOfNulls<SeekBar>(3)
            val tvs = arrayOfNulls<TextView>(3)
            
            fun createBoundRow(idx: Int, label: String) {
                val row = LinearLayout(this@MotorRealExperienceActivity).apply { orientation = LinearLayout.HORIZONTAL; gravity = Gravity.CENTER_VERTICAL; setPadding(0, 8, 0, 8) }
                val tvLabel = TextView(this@MotorRealExperienceActivity).apply { text = label; setTextColor(Color.WHITE); layoutParams = LinearLayout.LayoutParams(0, -2, 1f) }
                tvs[idx] = TextView(this@MotorRealExperienceActivity).apply { text = String.format(Locale.US, "%.1f cm", bounds[idx]); setTextColor(Color.CYAN); width = 120; gravity = Gravity.END }
                sbs[idx] = SeekBar(this@MotorRealExperienceActivity).apply {
                    max = 1200; progress = (bounds[idx]*10).toInt(); layoutParams = LinearLayout.LayoutParams(0, -2, 2f); setPadding(20,0,20,0)
                    setOnSeekBarChangeListener(object : SeekBar.OnSeekBarChangeListener {
                        override fun onProgressChanged(p0: SeekBar?, v: Int, p2: Boolean) { 
                            bounds[idx] = v / 10f; tvs[idx]?.text = String.format(Locale.US, "%.1f cm", bounds[idx])
                            if (idx == 0 && bounds[0] > bounds[1]) sbs[1]?.progress = v
                            if (idx == 1 && bounds[1] < bounds[0]) sbs[0]?.progress = v
                            if (idx == 1 && bounds[1] > bounds[2]) sbs[2]?.progress = v
                            if (idx == 2 && bounds[2] < bounds[1]) sbs[1]?.progress = v
                        }
                        override fun onStartTrackingTouch(p0: SeekBar?) {}
                        override fun onStopTrackingTouch(p0: SeekBar?) {}
                    })
                }
                row.addView(tvLabel); row.addView(sbs[idx]); row.addView(tvs[idx]); contentBox.addView(row)
            }
            createBoundRow(0, "边界: 超短 ↔ 短")
            createBoundRow(1, "边界: 短 ↔ 中")
            createBoundRow(2, "边界: 中 ↔ 长")

            policies.forEach { policy ->
                contentBox.addView(createSectionHeader("${policy.name} (不含硬件死区缩放)"))
                fun createFloatRow(label: String, initVal: Float, maxVal: Float, onValChange: (Float) -> Unit) {
                    val row = LinearLayout(this@MotorRealExperienceActivity).apply { orientation = LinearLayout.HORIZONTAL; gravity = Gravity.CENTER_VERTICAL; setPadding(0, 16, 0, 16) }
                    val tvLabel = TextView(this@MotorRealExperienceActivity).apply { text = label; setTextColor(Color.LTGRAY); layoutParams = LinearLayout.LayoutParams(0, -2, 1.3f) }
                    val tvVal = TextView(this@MotorRealExperienceActivity).apply { text = String.format(Locale.US, "%.1f cm", initVal); setTextColor(Color.CYAN); layoutParams = LinearLayout.LayoutParams(0, -2, 0.6f); gravity = Gravity.END }
                    val sb = SeekBar(this@MotorRealExperienceActivity).apply {
                        max = (maxVal * 10).toInt(); progress = (initVal * 10).toInt(); layoutParams = LinearLayout.LayoutParams(0, -2, 1f); setPadding(20,0,20,0)
                        setOnSeekBarChangeListener(object : SeekBar.OnSeekBarChangeListener {
                            override fun onProgressChanged(p0: SeekBar?, progress: Int, p2: Boolean) { val v = progress / 10f; tvVal.text = String.format(Locale.US, "%.1f cm", v); onValChange(v) }
                            override fun onStartTrackingTouch(p0: SeekBar?) {}; override fun onStopTrackingTouch(p0: SeekBar?) {}
                        })
                    }
                    row.addView(tvLabel); row.addView(sb); row.addView(tvVal); contentBox.addView(row)
                }
                createFloatRow("参考行程 (Ref)", policy.refStroke, 120f) { policy.refStroke = it }
                createFloatRow("触发向心 (Trigger)", policy.triggerThreshold, 30f) { policy.triggerThreshold = it }
                createFloatRow("退顶峰回程 (Return)", policy.returnThreshold, 30f) { policy.returnThreshold = it }
            }
        }
        
        fun updateTabs() {
            btnMale.background = getRoundedBg(if(editingGender==0) Color.CYAN else Color.DKGRAY, 16f)
            btnMale.setTextColor(if(editingGender==0) Color.BLACK else Color.WHITE)
            btnFemale.background = getRoundedBg(if(editingGender==1) Color.MAGENTA else Color.DKGRAY, 16f)
            btnFemale.setTextColor(if(editingGender==1) Color.BLACK else Color.WHITE)
            renderContent()
        }
        btnMale.setOnClickListener { editingGender = 0; updateTabs() }
        btnFemale.setOnClickListener { editingGender = 1; updateTabs() }
        
        tabRow.addView(btnMale); tabRow.addView(btnFemale)
        container.addView(tabRow)
        container.addView(contentBox)
        updateTabs()

        overlay.addView(container)
        root.addView(overlay)
        settingsOverlay = overlay
    }

    private fun updateParamLabels(mode: Int, r1: View?, r2: View?, l1: TextView?, l2: TextView?, ratioRow: View?) {
        r1?.visibility = View.VISIBLE
        r2?.visibility = View.VISIBLE
        ratioRow?.visibility = View.GONE
        
        when(mode) {
            0 -> { 
                r1?.visibility = View.GONE; r2?.visibility = View.GONE 
                ratioRow?.visibility = View.VISIBLE
            }
            1 -> { 
                l1?.text = "限制速度（cm/s）"; l2?.text = "强度系数 K"
            }
            2 -> { 
                l1?.text = "弹簧行程（cm）"; l2?.text = "劲度系数 K"
            }
            3, 4, 5 -> { 
                r1?.visibility = View.GONE; r2?.visibility = View.GONE
            }
        }
    }

