class MotorDetailPanel(context: Context, private val title: String, private val colorTheme: Int) : LinearLayout(context) {
    private val valTypeface = Typeface.MONOSPACE
    private val lblTypeface = Typeface.DEFAULT_BOLD
    
    private val tvTitle = TextView(context).apply { text = title; setTextColor(colorTheme); textSize = 12f; typeface = Typeface.DEFAULT_BOLD; }
    
    private var showAbsolutePos = false // [Fix 3 & 4] 切换绝对位置与向心行程
    
    private val tvForce = createValView()
    private val tvStrokeOrPos = createValView()
    private val tvPower = createValView()
    private val tvSpeed = createValView()
    private val tvConcentricTime = createValView()
    private val tvEccentricTime = createValView()

    private val tvStrokeLabel = TextView(context).apply {
        text = "向心行程 ⇌"
        textSize = 10f; setTextColor(Color.CYAN); typeface = Typeface.DEFAULT_BOLD; setPadding(12,6,12,6)
        background = GradientDrawable().apply { setColor(Color.DKGRAY); cornerRadius = 8f }
        setOnClickListener {
            showAbsolutePos = !showAbsolutePos
            text = if (showAbsolutePos) "实时位置 ⇌" else "向心行程 ⇌"
            setTextColor(if (showAbsolutePos) Color.YELLOW else Color.CYAN)
        }
    }

    private val tvState = TextView(context).apply { textSize = 32f; setTextColor(Color.YELLOW); typeface = lblTypeface; text = "准备" }
    private val tvRawCount = TextView(context).apply { textSize = 32f; setTextColor(Color.GREEN); typeface = lblTypeface; text = "0" }
    
    private val tvMonitor = TextView(context).apply { textSize = 10f; setTextColor(Color.GRAY); text = "Temp: -- | Err: --" }

    private fun createValView() = TextView(context).apply { textSize = 24f; setTextColor(Color.WHITE); typeface = valTypeface; text = "0" }

    init {
        orientation = VERTICAL
        background = GradientDrawable().apply { 
            setColor(0xFF2C2C2E.toInt()) 
            cornerRadius = 16f
        }
        setPadding(16, 16, 16, 16)
        
        addView(tvTitle)
        
        val rowMain = LinearLayout(context).apply {
            orientation = HORIZONTAL
            weightSum = 2f
            setPadding(0, 16, 0, 0)
            addView(createKVBlock("实时拉力（kg）", tvForce), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
            
            val strokeBlock = LinearLayout(context).apply {
                orientation = VERTICAL; gravity = Gravity.CENTER_HORIZONTAL
                addView(tvStrokeOrPos); addView(tvStrokeLabel)
            }
            addView(strokeBlock, LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
        }
        addView(rowMain)
        
        val rowSub = LinearLayout(context).apply {
            orientation = HORIZONTAL
            setPadding(0, 16, 0, 0)
            addView(createKVBlock("实时功率（w）", tvPower), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
            addView(createKVBlock("实时速度（m/s）", tvSpeed), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
        }
        addView(rowSub)

        val rowTime = LinearLayout(context).apply {
            orientation = HORIZONTAL
            setPadding(0, 16, 0, 0)
            addView(createKVBlock("向心时长（s）", tvConcentricTime), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
            addView(createKVBlock("离心时长（s）", tvEccentricTime), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
        }
        addView(rowTime)

        val rowState = LinearLayout(context).apply {
            orientation = HORIZONTAL
            setPadding(0, 24, 0, 8)
            addView(createKVBlock("单侧状态机", tvState), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
            addView(createKVBlock("单侧计次", tvRawCount), LayoutParams(0, LayoutParams.WRAP_CONTENT, 1f))
        }
        addView(rowState)
        
        addView(View(context).apply { setBackgroundColor(0xFF333333.toInt()); layoutParams = LayoutParams(-1, 1).apply { topMargin=8; bottomMargin=8 } })
        addView(tvMonitor)
    }
    
    private fun createKVBlock(label: String, valueView: TextView): LinearLayout {
        return LinearLayout(context).apply {
            orientation = VERTICAL
            gravity = Gravity.CENTER_HORIZONTAL
            addView(valueView)
            addView(TextView(context).apply { text = label; textSize = 10f; setTextColor(Color.GRAY); typeface = Typeface.DEFAULT_BOLD })
        }
    }

    fun update(force: Float, stroke: Float, state: String, power: Float, rawCount: Int,
               conTime: Float, eccTime: Float,
               temp: Int, errorCode: Int, absPos: Float, speed: Float) { 
        tvForce.text = String.format(Locale.US, "%.1f", force)
        tvStrokeOrPos.text = String.format(Locale.US, "%.0f", if (showAbsolutePos) absPos else stroke) 
        tvPower.text = power.toInt().toString()
        tvSpeed.text = String.format(Locale.US, "%.2f", speed / 100f)
        tvConcentricTime.text = String.format(Locale.US, "%.1f", conTime)
        tvEccentricTime.text = String.format(Locale.US, "%.1f", eccTime)
        tvState.text = state
        tvRawCount.text = "$rawCount"

        if (errorCode > 0) {
             tvMonitor.setTextColor(Color.RED)
             tvMonitor.text = "警告: 错误码 E$errorCode | 温度 ${temp}℃"
        } else {
             tvMonitor.setTextColor(Color.GRAY)
             tvMonitor.text = "设备: 正常 | 温度 ${temp}℃ | 绝对位置 ${absPos.toInt()}"
        }
    }
}

