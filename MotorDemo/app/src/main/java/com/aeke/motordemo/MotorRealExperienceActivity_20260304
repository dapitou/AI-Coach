    var activationSmoothRate: Int = 14, // [Fix] 默认 14
    var unloadDuration: Float = 0.5f,   // [Fix] 默认 0.5s
    var returnRatio: Float = 1.0f,      // [Fix] 离心比例 1.0
    var releaseProtectEnable: Boolean = false,
    var releaseSpeedLimit: Int = 190,
    var releaseDuration: Int = 4,
    var pullComp: Int = 0,
    var returnComp: Int = 0,
    var balanceSwitch: Boolean = false
)

// ===================================================================================
// V11.0.0 算法引擎 (User Behavior & Motor State Machine)
// ===================================================================================

class V11AlgorithmEngine {
    private val m1Processor = SingleMotorProcessor()
    private val m2Processor = SingleMotorProcessor()
    private val userProcessor = UserStateProcessor()
    
    // [产品定义修正] 文档要求: 底层强制平滑。由于协议层未下发Byte12/13平滑参数，
    // 此处必须开启软件算法滤波，Alpha调整为0.15以兼顾实时性与阻尼质感。
    private val filterAlpha = 0.15f 
    private var lastM1Force = 0f
    private var lastM2Force = 0f
    
    // [核心重构] 移除 AnalysisResult 数据类，改为可变成员变量 (Mutable Fields)
    // 目的: 实现 Zero-Allocation (零GC)，避免每秒100次的对象创建导致内存抖动
    var leftStateStr: String = ""
    var rightStateStr: String = ""
    var leftStroke: Float = 0f
    var rightStroke: Float = 0f
    var userStateStr: String = ""
    var totalCount: Int = 0
    var m1PowerWatts: Float = 0f
    var m2PowerWatts: Float = 0f
    var filteredM1Force: Float = 0f
    var filteredM2Force: Float = 0f
    var leftRawCount: Int = 0
    var rightRawCount: Int = 0

    // [Feature] 左右侧向心/离心时长
    var leftConcentricTime: Float = 0f
    var leftEccentricTime: Float = 0f
    var rightConcentricTime: Float = 0f
    var rightEccentricTime: Float = 0f
    
    // [Data Recovery] Storing hardware monitor states
    var m1Temp: Int = 0
    var m2Temp: Int = 0
    var m1ErrorCode: Int = 0
    var m2ErrorCode: Int = 0
    var m1AbsPos: Float = 0f
    var m2AbsPos: Float = 0f
    var m1Speed: Float = 0f
    var m2Speed: Float = 0f

    // 事件标志位 (用于锁存)
    var currentEvent: String = ""
    var hasNewEvent: Boolean = false // 标记当前帧是否产生了新事件
    

    // 时间追踪 (用于计算 dt)
    private var lastProcessTime = 0L

    // [Fix 1] 速度导数滤波缓冲队列
    private val m1SpeedBuffer = ArrayDeque<Float>()
    private val m2SpeedBuffer = ArrayDeque<Float>()
    private fun getSmoothedSpeed(buffer: ArrayDeque<Float>, newSpeed: Float): Float {
        if (buffer.size >= 3) buffer.removeFirst()
        buffer.add(newSpeed)
        return buffer.average().toFloat()
    }

    fun process(model: PowerControlModelInterface) {
        hasNewEvent = false // Reset per frame
        
        // 提取数据 (PowerControlModelInterface 已经是解析好的物理值)
        // [Fix 5. 功率突变] 增加 Clamp 过滤，防止协议解析错误或硬件噪声导致的异常值
        val m1F = model.m1Power / 100f
        var m1V = model.m1Rate.toFloat()
        val m1P = model.m1Distance.toFloat()
        
        val m2F = model.m2Power / 100f
        var m2V = model.m2Rate.toFloat()
        val m2P = model.m2Distance.toFloat()
        
        // Clamp Protection
        if (abs(m1V) > 1000f) m1V = m1Speed // Ignore spike > 10m/s, use last valid
        if (abs(m2V) > 1000f) m2V = m2Speed
        
        // [Fix 1] 执行滑动窗口滤波
        m1V = getSmoothedSpeed(m1SpeedBuffer, m1V)
        m2V = getSmoothedSpeed(m2SpeedBuffer, m2V)

        // 3. 功率计算 (P = F * v)。注意 Ak21 速度单位 cm/s，力单位 kg。
        // P (W) = (kg * 9.8) * (cm/s / 100)
        // [Fix 5] 功率突变修复：增加 max 限制，防止计算出负功率或异常大功率
        val rawPower1 = m1F * m1V * 0.098f
        val rawPower2 = m2F * m2V * 0.098f
        val power1 = if (rawPower1 in 0f..2000f) rawPower1 else 0f // 过滤异常值
        val power2 = if (rawPower2 in 0f..2000f) rawPower2 else 0f

        // 计算 dt (s)
        val now = System.currentTimeMillis()
        val dt = if (lastProcessTime == 0L) 0.1f else (now - lastProcessTime) / 1000f
        lastProcessTime = now
        // 限制 dt 防止卡顿导致积分爆炸 (Max 0.2s)
        val safeDt = min(dt, 0.2f)

        // 0. 数据平滑 (Low Pass Filter)
        val sm1Force = lowPassFilter(m1F, lastM1Force)
        val sm2Force = lowPassFilter(m2F, lastM2Force)
        lastM1Force = sm1Force
        lastM2Force = sm2Force

        // [Architecture] 侧向抑制与动态意图判断 (单侧锁定保护)
        var m1Inhibited = false
        var m2Inhibited = false
        val m1Active = m1Processor.ctx.state in listOf(SingleMotorProcessor.MotorState.CONCENTRIC, SingleMotorProcessor.MotorState.PEAK, SingleMotorProcessor.MotorState.ECCENTRIC) && m1Processor.ctx.realStroke > 10f
        val m2Active = m2Processor.ctx.state in listOf(SingleMotorProcessor.MotorState.CONCENTRIC, SingleMotorProcessor.MotorState.PEAK, SingleMotorProcessor.MotorState.ECCENTRIC) && m2Processor.ctx.realStroke > 10f

        if (m1Active && !m2Active) {
            m2Inhibited = !(m2P - m2Processor.ctx.startPos > 15f && abs(m2V) > 20f)
        } else if (m2Active && !m1Active) {
            m1Inhibited = !(m1P - m1Processor.ctx.startPos > 15f && abs(m1V) > 20f)
        }
        m1Processor.isLockedToPrepare = m1Inhibited
        m2Processor.isLockedToPrepare = m2Inhibited

        // 1. 物理层处理 (Motor Physics Layer)
        val p1 = m1Processor.update(sm1Force, m1P, m1V, safeDt)
        val p2 = m2Processor.update(sm2Force, m2P, m2V, safeDt)
        
        // 2. 用户行为层处理 (User Behavior Layer)
        // 融合双电机数据，判定用户当前处于什么阶段
        val userStateResult = userProcessor.update(p1, p2)

        // 更新公共字段 (无内存分配)
        leftStateStr = p1.state.cnName
        rightStateStr = p2.state.cnName
        leftStroke = m1Processor.concentricStroke // [Fix] 从处理器中直接获取向心行程记录
        rightStroke = m2Processor.concentricStroke
        userStateStr = userStateResult.stateName
        totalCount = userProcessor.totalCount
        m1PowerWatts = power1
        m2PowerWatts = power2
        filteredM1Force = sm1Force
        filteredM2Force = sm2Force
        leftRawCount = m1Processor.rawCount
        rightRawCount = m2Processor.rawCount

        // 捕获疲劳宽容事件
        if (p1.isFatigueTolerated || p2.isFatigueTolerated) {
            currentEvent = "疲劳宽容计次: 幅度不足/力竭半程"
            hasNewEvent = true
        }

        // Update Durations
        leftConcentricTime = m1Processor.concentricDuration
        leftEccentricTime = m1Processor.eccentricDuration
        rightConcentricTime = m2Processor.concentricDuration
        rightEccentricTime = m2Processor.eccentricDuration
        
        // Capture hardware state for UI display
        m1Temp = model.m1Temp
        m2Temp = model.m2Temp
        m1ErrorCode = model.m1ErrorCode
        m2ErrorCode = model.m2ErrorCode
        m1AbsPos = m1P
        m2AbsPos = m2P
        m1Speed = m1V
        m2Speed = m2V

        currentEvent = userStateResult.event ?: ""
        if (userStateResult.event != null) hasNewEvent = true
    }
    
    // [Feature 2] 彻底重置计次与状态机基准
    fun resetCounters() {
        totalCount = 0
        leftRawCount = 0
        rightRawCount = 0
        m1Processor.reset()
        m2Processor.reset()
        userProcessor.reset()
    }

    private fun lowPassFilter(current: Float, last: Float): Float {
        if (last == 0f) return current
        return last + filterAlpha * (current - last)
    }
}

// ===================================================================================
// 本地硬件适配层 (Local Hardware Layer)
// 替代缺失的 power 模块，直接管理串口与协议，修复 Unresolved reference 问题
// ===================================================================================

interface PowerControlModelInterface {
    val m1Power: Int // Raw Value: kg * 100
    val m1Rate: Int  // Signed: cm/s
    val m1Distance: Int // Signed: cm
    val m2Power: Int // Raw Value
    val m2Rate: Int
    val m2Distance: Int
    val m1Temp: Int
    val m2Temp: Int
    val m1ErrorCode: Int
    val m2ErrorCode: Int
}

class LocalBenMoPowerHelper {
    var isSmooth: Boolean = false
    var smoothRate: Int = 0
    
    private var dataListener: ((PowerControlModelInterface) -> Unit)? = null
    private val serialManager = SerialManager()
    private val parser = ProtocolParser()
    private var isReading = false

    fun init() {
        if (serialManager.open("/dev/ttyS9")) {
            isReading = true
            Thread { readLoop() }.start()
        }
    }
    
    fun setOnDataListener(listener: (PowerControlModelInterface) -> Unit) {
        this.dataListener = listener
    }

    fun setEnablePowerMode() = sendHex("640202AA")
    fun setUnEnablePowerMode() = sendHex("64020255")
    fun setResetMode() = sendHex("640201FC")

    fun sendDeviceRestart() = sendHex("6402FF")

    fun setFullMotorModeInt(modeCode: Int, huiLi: Int, laLi: Int, param1: Int, param2: Int) {
        val cmd = ByteArray(32)
        cmd[0] = 0x64; cmd[1] = 0x02; cmd[2] = 0x01; cmd[3] = modeCode.toByte()
        
        cmd[4] = ((huiLi shr 8) and 0xFF).toByte()
        cmd[5] = (huiLi and 0xFF).toByte()
        
        cmd[6] = ((laLi shr 8) and 0xFF).toByte()
        cmd[7] = (laLi and 0xFF).toByte()
        
        cmd[8] = param1.toByte()
        cmd[9] = param2.toByte()

        if (isSmooth) {
            cmd[12] = 0x01
            cmd[13] = smoothRate.toByte()
        }
        
        fillCRC(cmd)
        cmd[30] = 0x0D; cmd[31] = 0x0A
        serialManager.write(cmd)
    }

    fun setReleaseProtection(enable: Boolean, speed: Int, duration: Int) {
        val cmd = ByteArray(32)
        cmd[0] = 0x64; cmd[1] = 0x02
        cmd[2] = 0xA0.toByte() 
        cmd[3] = if (enable) 0x01 else 0x00
        val speedVal = (speed / 10).coerceIn(1, 30)
        cmd[4] = speedVal.toByte()
        cmd[5] = duration.toByte()
        
        fillCRC(cmd)
        cmd[30] = 0x0D; cmd[31] = 0x0A
        serialManager.write(cmd)
    }

    fun setForceCompensation(returnComp: Int, pullComp: Int) {
        val cmd = ByteArray(32)
        cmd[0] = 0x64; cmd[1] = 0x02
        cmd[2] = 0x06.toByte()
        
        cmd[4] = ((returnComp shr 8) and 0xFF).toByte()
        cmd[5] = (returnComp and 0xFF).toByte()
        cmd[6] = ((pullComp shr 8) and 0xFF).toByte()
        cmd[7] = (pullComp and 0xFF).toByte()

        fillCRC(cmd)
        cmd[30] = 0x0D; cmd[31] = 0x0A
        serialManager.write(cmd)
    }

    fun setBalanceSwitch(enable: Boolean) {
        val cmd = ByteArray(32)
        cmd[0] = 0x64; cmd[1] = 0x02
        cmd[2] = 0xA2.toByte()
        cmd[3] = if (enable) 0x01 else 0x00
        
        fillCRC(cmd)
        cmd[30] = 0x0D; cmd[31] = 0x0A
        serialManager.write(cmd)
    }

    private fun sendHex(prefix: String) {
        val cmd = ByteArray(32)
        val pBytes = hexStringToBytes(prefix)
        System.arraycopy(pBytes, 0, cmd, 0, pBytes.size)
        fillCRC(cmd)
        cmd[30] = 0x0D; cmd[31] = 0x0A
        serialManager.write(cmd)
    }

    private fun readLoop() {
        val buffer = ByteArray(1024)
        while (isReading) {
            val len = serialManager.read(buffer)
            if (len > 0) {
                val frames = parser.parse(buffer, len)
                frames.forEach { dataListener?.invoke(it) }
            } else {
                Thread.sleep(5)
            }
        }
    }
    
    private fun fillCRC(cmd: ByteArray) {
        var crc = 0x00
        for (i in 0 until 29) { 
            crc = CRC8.compute(crc, cmd[i].toInt() and 0xFF) 
        }
        cmd[29] = crc.toByte()
    }

    private fun hexStringToBytes(s: String): ByteArray {
        val len = s.length
        val data = ByteArray(len / 2)
        var i = 0
        while (i < len) {
            data[i / 2] = ((Character.digit(s[i], 16) shl 4) + Character.digit(s[i + 1], 16)).toByte()
            i += 2
        }
        return data
    }
}

data class LocalPowerData(
    override val m1Power: Int, override val m1Rate: Int, override val m1Distance: Int,
    override val m2Power: Int, override val m2Rate: Int, override val m2Distance: Int,
    override val m1Temp: Int, override val m2Temp: Int,
    override val m1ErrorCode: Int, override val m2ErrorCode: Int
) : PowerControlModelInterface

class ProtocolParser {
    private val buffer = ByteArray(2048)
    private var wIdx = 0
    
    fun parse(data: ByteArray, len: Int): List<PowerControlModelInterface> {
        if (wIdx + len > buffer.size) wIdx = 0
        System.arraycopy(data, 0, buffer, wIdx, len)
        wIdx += len
        
        val res = ArrayList<PowerControlModelInterface>()
        var ptr = 0
        val frameLen = 40 
        
        while (ptr <= wIdx - frameLen) {
            if (buffer[ptr] == 0x64.toByte() && buffer[ptr+1] == 0x02.toByte()) {
                 val m1Force = getUInt16(ptr + 3) 
                 val m1Rate = getSInt16(ptr + 5)
                 val m1Dist = getSInt16(ptr + 7)
                 
                 val m2Force = getUInt16(ptr + 14)
                 val m2Rate = getSInt16(ptr + 16)
                 val m2Dist = getSInt16(ptr + 18)
                 
                 val m1E = buffer[ptr + 25].toInt()
                 val m2E = buffer[ptr + 26].toInt()
                 val m1T = buffer[ptr + 31].toInt()
                 val m2T = buffer[ptr + 32].toInt()
                 
                 res.add(LocalPowerData(m1Force, m1Rate, m1Dist, m2Force, m2Rate, m2Dist, m1T, m2T, m1E, m2E))
                 ptr += frameLen
            } else {
                ptr++
            }
        }
        
        if (ptr < wIdx) {
            val rem = wIdx - ptr
            System.arraycopy(buffer, ptr, buffer, 0, rem)
            wIdx = rem
        } else {
            wIdx = 0
        }
        return res
    }
    
    private fun getUInt16(idx: Int): Int {
        return ((buffer[idx].toInt() and 0xFF) shl 8) or (buffer[idx+1].toInt() and 0xFF)
    }

    private fun getSInt16(idx: Int): Int {
        val high = buffer[idx].toInt() and 0xFF
        val low = buffer[idx+1].toInt() and 0xFF
        val raw = (high shl 24) or (low shl 16)
        return raw shr 16 
    }
}

class SerialManager {
    private var fis: FileInputStream? = null
    private var fos: FileOutputStream? = null
    
    fun open(path: String): Boolean {
        return try {
            val f = File(path)
            if (!f.canRead()) return false
            fis = FileInputStream(f)
            fos = FileOutputStream(f)
            true
        } catch(e: Exception) { false }
    }
    
    fun read(b: ByteArray): Int = fis?.read(b) ?: 0
    
    @Synchronized 
    fun write(b: ByteArray) {
        try {
            fos?.write(b)
            fos?.flush()
        } catch (_: Exception) {}
    }
}

object CRC8 {
    fun compute(crc: Int, data: Int): Int {
        var c = crc xor data
        repeat(8) {
             c = if ((c and 0x01) != 0) (c ushr 1) xor 0x8C else (c ushr 1)
        }
        return c
    }
}

// 单电机物理状态机
class SingleMotorProcessor {
    enum class MotorState(val cnName: String) {
        PREPARE("准备"),
        CONCENTRIC("向心"),
        PEAK("顶峰"),
        ECCENTRIC("离心"),
        RESET("复位")
    }
    
    data class PhysicsContext(
        var state: MotorState = MotorState.PREPARE,
        var startPos: Float = 0f,
        var realStroke: Float = 0f,
        var realVel: Float = 0f, 
        var stdStroke: Float = 50f,
        var work: Float = 0f,    
        var impulse: Float = 0f, 
        var duration: Float = 0f, 
        var triggeredValidPeak: Boolean = false, 
        var isSetupPeak: Boolean = false,        
        var isFatigueTolerated: Boolean = false, // [Feature] 标记是否为力竭宽容计次
        var retroactiveCounts: Int = 0           // [Feature] 幽灵补发计次
    ) // KE-ZL-202309-0

    val ctx = PhysicsContext()
    val baseline = DynamicBaseline()
    var rawCount = 0
    var isLockedToPrepare = false 
    
    var concentricDuration = 0f
    var eccentricDuration = 0f
    var setBestVelocity = 0f
    
    var concentricStroke = 0f // [Fix] 像时长一样记录向心行程
    var eccentricStroke = 0f  // [Fix] 像时长一样记录离心行程
    var peakConcentricStroke = 0f // [Fix] 纯向心行程的相对峰值
    private var startOfConcentricPos = 0f // [Fix] 记录每次向心的实际物理起点
    private var lowestPosInPrepare = Float.MAX_VALUE 
    private var lowestPosInEccentric = Float.MAX_VALUE 
    private var highestPosInPeak = 0f 
    private var posAtPhaseStart = 0f // [Fix] 记录相位开始时的绝对位置作为该相位的起点
    private var eccentricStopFrames = 0 // [Fix 3] 离心超时计数器
    
    private var phaseStartTime = 0L 
    private var workAccumulator = 0f 
    private var impulseAccumulator = 0f 
    private var continuousDropFrames = 0 
    private var lastFrameStroke = 0f     

    fun reset() {
        ctx.state = MotorState.PREPARE
        ctx.work = 0f; ctx.impulse = 0f; ctx.duration = 0f
        rawCount = 0
        workAccumulator = 0f; impulseAccumulator = 0f
        concentricDuration = 0f; eccentricDuration = 0f; setBestVelocity = 0f
        concentricStroke = 0f; eccentricStroke = 0f
        peakConcentricStroke = 0f
        startOfConcentricPos = 0f
        lowestPosInPrepare = Float.MAX_VALUE
        lowestPosInEccentric = Float.MAX_VALUE
        highestPosInPeak = 0f
        posAtPhaseStart = 0f
        eccentricStopFrames = 0
        baseline.reset()
    }

    fun update(force: Float, pos: Float, speed: Float, dt: Float): PhysicsContext {
        val speedMps = speed / 100f 
        
        ctx.triggeredValidPeak = false
        ctx.isSetupPeak = false
        ctx.isFatigueTolerated = false
        ctx.retroactiveCounts = 0

        if (isLockedToPrepare) {
            if (ctx.state != MotorState.PREPARE && ctx.state != MotorState.RESET) transitionTo(MotorState.RESET, pos)
            ctx.state = MotorState.PREPARE
            return ctx
        }

        baseline.update(force, pos, speedMps, ctx.state)
        
        ctx.startPos = baseline.stdStartPos 
        ctx.realStroke = max(0f, pos - ctx.startPos) 
        ctx.realVel = speed
        ctx.stdStroke = baseline.stdStroke

        if (ctx.state == MotorState.CONCENTRIC) {
            val dStroke = max(0f, speedMps * dt) 
            val dWork = (force * 9.8f) * dStroke
            workAccumulator += dWork
        }
        
        if (force > 1.0f) { 
            impulseAccumulator += (force * 9.8f) * dt
        }
        
        ctx.work = workAccumulator
        ctx.impulse = impulseAccumulator
        ctx.duration = (System.currentTimeMillis() - phaseStartTime) / 1000f

        // 高精度跟踪物理极值点，为相对距离做强力锚点
        if (ctx.state == MotorState.PREPARE || ctx.state == MotorState.RESET) {
            if (pos < lowestPosInPrepare) lowestPosInPrepare = pos
        } else if (ctx.state == MotorState.ECCENTRIC) {
            if (pos < lowestPosInEccentric) lowestPosInEccentric = pos
        } else if (ctx.state == MotorState.PEAK) {
            if (pos > highestPosInPeak) highestPosInPeak = pos
        }

        // 1. 底层幽灵推演变量（实时跟踪位置供状态机防抖，不受视觉锁定影响）
        val currentRelStroke = max(0f, pos - startOfConcentricPos)

        // [Fix] 核心修复：10Hz下转折帧的位置必然回落，向心行程绝不可跟随回缩！
        // 采用单向棘轮机制，强制锁定并展示本次发力的绝对巅峰数值
        if (ctx.state == MotorState.CONCENTRIC || ctx.state == MotorState.PEAK) {
            if (currentRelStroke > peakConcentricStroke) {
                peakConcentricStroke = currentRelStroke
            }
            concentricStroke = peakConcentricStroke // 取整个行程中的巅峰数字，1毫米都不会回缩
            
            if (ctx.state == MotorState.CONCENTRIC) {
                concentricDuration = ctx.duration
            }
        } else if (ctx.state == MotorState.ECCENTRIC) {
            eccentricDuration = ctx.duration
            eccentricStroke = max(0f, posAtPhaseStart - pos) 
        }

        val policy = StrokeConfig.getScaledPolicy() 

        when (ctx.state) {
            MotorState.PREPARE -> {
                continuousDropFrames = 0
                
                // [Fix] 动态相对触发：只要从稳定低点向上拉动了触发阀值即进向心，不再强求回到0
                val strokeFromLowest = pos - lowestPosInPrepare
                if (strokeFromLowest > policy.triggerThreshold && speedMps > 0.05f) {
                    transitionTo(MotorState.CONCENTRIC, pos)
                }
            }
            MotorState.CONCENTRIC -> {
                // [Fix 2] 极其关键：必须用历史峰值来判断高度，防止 10Hz 回落造成的瞬时位置坍塌导致不进顶峰
                val isHighEnough = peakConcentricStroke > (baseline.stdStroke * 0.4f) || peakConcentricStroke > policy.triggerThreshold 
                val isTurning = speedMps < 0.0f 
                val isStatic = abs(speedMps) < 0.05f && peakConcentricStroke > (baseline.stdStroke * 0.7f) 
                
                if (isHighEnough && (isTurning || isStatic)) { 
                    transitionTo(MotorState.PEAK, pos)
                } else if (isTurning && currentRelStroke < policy.staticZone) {
                    // [Fix 3] 动作打断保护：如果拉起没达标，且回落到底部，直接重置，防止状态机死锁在向心
                    transitionTo(MotorState.RESET, pos)
                }
                if (speedMps < -1.5f) transitionTo(MotorState.RESET, pos)
            }
            MotorState.PEAK -> {
                if (currentRelStroke < lastFrameStroke) {
                    continuousDropFrames++
                } else {
                    continuousDropFrames = 0
                }
                lastFrameStroke = currentRelStroke
                
                if (continuousDropFrames >= 3 && (peakConcentricStroke - currentRelStroke) > policy.returnThreshold) {
                    transitionTo(MotorState.ECCENTRIC, pos)
                }
                if (speedMps > 0.05f && currentRelStroke >= peakConcentricStroke) {
                    transitionTo(MotorState.CONCENTRIC, pos)
                }
            }
            MotorState.ECCENTRIC -> {
                if (abs(speedMps) < 0.05f) {
                    eccentricStopFrames++
                } else {
                    eccentricStopFrames = 0
                }
                
                // [Fix 4] 复位判定纯相对化，直接利用 concentricStroke (已消除漂移) 替代 realStroke
                if (currentRelStroke < policy.staticZone || (eccentricStopFrames >= 5 && currentRelStroke < baseline.stdStroke * 0.4f)) {
                    transitionTo(MotorState.RESET, pos)
                }
                val strokeFromLowest = pos - lowestPosInEccentric
                if (speedMps > 0.05f && strokeFromLowest > policy.triggerThreshold * 0.6f) {
                    transitionTo(MotorState.CONCENTRIC, pos)
                }
            }
            MotorState.RESET -> { 
                transitionTo(MotorState.PREPARE, pos)
            }
        }

        return ctx
    }

    private fun transitionTo(newState: MotorState, currentPos: Float) {
        if (ctx.state == newState) return
        val lastState = ctx.state
        ctx.state = newState
        
        phaseStartTime = if (newState == MotorState.CONCENTRIC) System.currentTimeMillis() - 100 else System.currentTimeMillis()
        posAtPhaseStart = currentPos // [Fix] 像计时一样，在状态流转时重置此相位的起点快照
        
        if (newState == MotorState.PREPARE || newState == MotorState.RESET) {
            lowestPosInPrepare = currentPos
        } else if (newState == MotorState.ECCENTRIC) {
            lowestPosInEccentric = currentPos
            posAtPhaseStart = highestPosInPeak 
        } else if (newState == MotorState.PEAK) {
            highestPosInPeak = currentPos
        }
        
        if (newState == MotorState.CONCENTRIC) {
            if (lastState != MotorState.PEAK) {
                // 提取出上一个动作真正的波谷极限作为新一轮的向心起点！1毫米都不会吃掉
                startOfConcentricPos = if (lastState == MotorState.ECCENTRIC) min(lowestPosInEccentric, currentPos) else min(lowestPosInPrepare, currentPos)
                peakConcentricStroke = 0f 
                concentricStroke = max(0f, currentPos - startOfConcentricPos) // 瞬间同步已拉出的距离
                eccentricStroke = 0f
            }
        }
        
        if (newState == MotorState.PREPARE || newState == MotorState.RESET) {
            workAccumulator = 0f
            impulseAccumulator = 0f
            
            val currentAvg = peakConcentricStroke / max(0.1f, concentricDuration)
            if (currentAvg > setBestVelocity) setBestVelocity = currentAvg
        }
        
        if (lastState == MotorState.CONCENTRIC && (newState == MotorState.PEAK || newState == MotorState.ECCENTRIC)) {
             val policy = StrokeConfig.getScaledPolicy()
             
             // [计次闭环修复] 严格按需求文档：计次阈值 = 0.8 * 标准行程。冷启动采用设定参考值的 50%
             val countThreshold = if (baseline.isCalibrated) (baseline.stdStroke * 0.8f) else (policy.refStroke * 0.5f)
             
             // [计次闭环修复] 强制要求绝对行程 > 2.5cm 防伪触发，特别是针对超短行程动作
             val isStrokeAbsoluteValid = peakConcentricStroke >= 2.5f
             
             val currentAvg = peakConcentricStroke / max(0.1f, concentricDuration)
             val isFatigued = currentAvg < (setBestVelocity * 0.85f) || (ctx.realVel < 5.0f && concentricDuration > 2.0f)
             
             if (!baseline.isCalibrated) {
                 if (peakConcentricStroke >= countThreshold && isStrokeAbsoluteValid) {
                     ctx.triggeredValidPeak = true
                     rawCount++
                     baseline.submitValidStroke(peakConcentricStroke, false)
                    } else if (peakConcentricStroke > policy.triggerThreshold) { 
                     // 动作未达 50% 但超过了起势识别阀值，只建库不计次
                 ctx.isSetupPeak = true
                     baseline.submitValidStroke(peakConcentricStroke, false)
                 }
             } else {
                 if (peakConcentricStroke >= countThreshold && isStrokeAbsoluteValid) { 
                     ctx.triggeredValidPeak = true
                     rawCount++
                     baseline.submitValidStroke(peakConcentricStroke, false)
                 } else if (peakConcentricStroke >= countThreshold * 0.7f && isFatigued && isStrokeAbsoluteValid) {
                     ctx.triggeredValidPeak = true
                     ctx.isFatigueTolerated = true
                     rawCount++
                     baseline.submitValidStroke(peakConcentricStroke, false)
                 }
                 
                 // [Fix] 彻底解决自由训练“长程切短程卡死”的 Bug：
                 // 如果动作被正常阈值拦截（没达标），但幅度 > 8cm（显著的短程动作），
                 // 独立将其喂给基准池进行 CV 变异分析，强制向下兼容与平滑降级。
                 if (StrokeConfig.isFreeTraining && peakConcentricStroke < countThreshold && peakConcentricStroke > 8.0f) {
                      val retro = baseline.submitValidStroke(peakConcentricStroke, true)
                     if (retro > 0) {
                         rawCount += retro
                         ctx.retroactiveCounts = retro
                     }
                 }
             }
        }
    }
}

class UserStateProcessor {
    enum class UserState(val cnName: String) {
        PREPARE("准备"),
        CONCENTRIC("向心(拉)"),
        PEAK("顶峰(停)"), 
        ECCENTRIC("离心(放)"),
        RESET("复位")
    }
    data class StateResult(val stateName: String, val event: String?)

    private var state = UserState.PREPARE
    var totalCount = 0 
    
    private var leftCount = 0
    private var rightCount = 0
    private var lastLeftState = SingleMotorProcessor.MotorState.PREPARE
    private var lastRightState = SingleMotorProcessor.MotorState.PREPARE
    
    private var lastLeftPeakTime = 0L
    private var lastRightPeakTime = 0L
    private var lastMergedTime = 0L

    fun reset() {
        state = UserState.PREPARE
        totalCount = 0; leftCount = 0; rightCount = 0
        lastLeftState = SingleMotorProcessor.MotorState.PREPARE
        lastRightState = SingleMotorProcessor.MotorState.PREPARE
    }

    fun update(leftCtx: SingleMotorProcessor.PhysicsContext, rightCtx: SingleMotorProcessor.PhysicsContext): StateResult {
        var event: String? = null
        val lastUserState = state
        val leftState = leftCtx.state
        val rightState = rightCtx.state

        val now = System.currentTimeMillis()

        if (leftCtx.triggeredValidPeak) {
             leftCount++
             lastLeftPeakTime = now
             event = tryMergeCount(now)
        } else if (leftCtx.isSetupPeak) {
             event = "高位起势 (Setup L)"
        }
        
        if (rightCtx.triggeredValidPeak) {
             rightCount++
             lastRightPeakTime = now
             event = tryMergeCount(now)
        } else if (rightCtx.isSetupPeak) {
             event = "高位起势 (Setup R)"
        }
        
        lastLeftState = leftState
        lastRightState = rightState

        state = when {
            leftState == SingleMotorProcessor.MotorState.PREPARE && rightState == SingleMotorProcessor.MotorState.PREPARE -> UserState.PREPARE
            leftState == SingleMotorProcessor.MotorState.RESET && rightState == SingleMotorProcessor.MotorState.RESET -> UserState.RESET
            leftState == SingleMotorProcessor.MotorState.PEAK || rightState == SingleMotorProcessor.MotorState.PEAK -> UserState.PEAK 
            leftState == SingleMotorProcessor.MotorState.CONCENTRIC || rightState == SingleMotorProcessor.MotorState.CONCENTRIC -> UserState.CONCENTRIC
            leftState == SingleMotorProcessor.MotorState.ECCENTRIC || rightState == SingleMotorProcessor.MotorState.ECCENTRIC -> UserState.ECCENTRIC
            else -> state 
        }

        if (lastUserState != state && event == null) {
            event = "用户状态 -> ${state.cnName}"
        }

        return StateResult(state.cnName, event)
    }
    
    private fun tryMergeCount(now: Long): String {
        if (now - lastMergedTime < 400) return "同步动作(Merged)"
        
        val diff = abs(lastLeftPeakTime - lastRightPeakTime)
        if (diff < 300) { 
            lastMergedTime = now
            return "双侧同步 (Sync)"
        } else {
            totalCount++
            return "有效计次 +1"
        }
    }
}

class DynamicBaseline {
    var stdStartPos: Float = 0f
        private set 
    var stdStroke: Float = 50f 
        private set
    var isCalibrated: Boolean = false 
        private set

    private val posBuffer = ArrayDeque<Float>()
    private val strokeHistory = ArrayDeque<Float>()
    private val cvHistory = ArrayDeque<Float>() 
    private var validRepCount = 0
    private var missedStreak = 0

    fun reset() {
        isCalibrated = false
        stdStartPos = 0f
        stdStroke = 50f
        posBuffer.clear()
        strokeHistory.clear()
        cvHistory.clear()
        validRepCount = 0
        missedStreak = 0
    }
    
    fun forceCalibrate(stroke: Float) {
        strokeHistory.add(stroke)
        stdStroke = max(stroke, StrokeConfig.getScaledPolicy().triggerThreshold)
        isCalibrated = true
    }
    
    fun submitValidStroke(lastStroke: Float, wasMissed: Boolean): Int {
        val policy = StrokeConfig.getScaledPolicy()
        if (!isCalibrated) {
            stdStroke = max(lastStroke, policy.triggerThreshold)
            strokeHistory.add(stdStroke)
            isCalibrated = true
            return 0
        }
        
        if (StrokeConfig.isFreeTraining) {
            if (wasMissed) {
                missedStreak++
            } else {
                missedStreak = 0
            }

            if (cvHistory.size >= 3) cvHistory.removeFirst()
            cvHistory.add(lastStroke)
            if (cvHistory.size >= 3) {
                val avg = cvHistory.average().toFloat()
                val variance = cvHistory.map { (it - avg) * (it - avg) }.sum() / cvHistory.size
                val sd = sqrt(variance.toDouble()).toFloat()
                val cv = if (avg > 0) sd / avg else 1f
                if (cv < 0.20f) { 
                    val bounds = StrokeConfig.getScaledBounds()
                    val newMode = when {
                        avg < bounds[0] -> 0
                        avg < bounds[1] -> 1
                        avg < bounds[2] -> 2
                        else -> 3
                    }
                    if (newMode != StrokeConfig.currentIndex) {
                        StrokeConfig.currentIndex = newMode
                        stdStroke = max(avg, policy.triggerThreshold)
                        validRepCount = 0
                        strokeHistory.clear()
                        strokeHistory.add(stdStroke)
                        val retro = missedStreak
                        cvHistory.clear()
                        missedStreak = 0
                        return retro
                    }
                }
            }
        }

        if (lastStroke in (stdStroke * 0.5f)..(stdStroke * 1.5f)) {
            validRepCount++
            if (validRepCount <= 3 || lastStroke >= stdStroke) {
                if (strokeHistory.size >= 5) strokeHistory.removeFirst()
                strokeHistory.add(lastStroke)
                val baseLimit = if (StrokeConfig.isFreeTraining) 5f else policy.refStroke * 0.6f // [Fix] 给足疲劳下探空间
                stdStroke = max(strokeHistory.average().toFloat(), baseLimit)
            }
        }
        return 0
    }

    fun update(force: Float, pos: Float, vel: Float, currentState: SingleMotorProcessor.MotorState) {
        val policy = StrokeConfig.getScaledPolicy()
        
        if (posBuffer.size >= 10) posBuffer.removeFirst() 
        posBuffer.add(pos)

        if (currentState == SingleMotorProcessor.MotorState.PREPARE || currentState == SingleMotorProcessor.MotorState.RESET) { 
            val minPos = posBuffer.minOrNull() ?: pos
            val maxPos = posBuffer.maxOrNull() ?: pos
            
            // [Fix] 极简的基准位置收敛：只要设备停稳、波动小，就立即自动归零，不再强绑定拉力张力限制
            if (abs(vel) < 0.1f && (maxPos - minPos) < policy.staticZone) {
                stdStartPos = posBuffer.average().toFloat()
            }
        }
    }
}

